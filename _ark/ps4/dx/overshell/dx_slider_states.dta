#define CALIBRATION_DATA
(
   {set $dxsettings {array ()}}
   {push_back $dxsettings " "}
   {push_back $dxsettings {sprintf " - Video: %d ms + " {* {get_video_calibration} -1}}}
   {push_back $dxsettings {sprintf " - Audio: %d ms + " {* {get_audio_calibration} -1}}}
   {push_back $dxsettings "Per-Controller Calibration"}
   {$this setup_confirm_actions a $dxsettings}

)
;New Calibration Sliders
(dxState_CalibrationSliders
   (view {$this get_auto_list_view})
   (enter
      CALIBRATION_DATA
      {set $slider_selected FALSE}
      {$this setup_tooltip kAction_Option os_reset} ;41 char limit
      {$this reset_list_focus }
   )
   (SELECT_MSG
      {local $list_data {($objId UIListCom) get_data_in_column token}}
      {switch $list_data 
         ({sprintf " - Video: %d ms + " {* {get_video_calibration} -1}}
            {set $slider_selected {! $slider_selected}}
            {if_else $slider_selected
               {do
                  {set $slider_type video}
                  {$this show_tooltip}
               }
               {$this hide_tooltip}
            }
         )
         ({sprintf " - Audio: %d ms + " {* {get_audio_calibration} -1}}
            {set $slider_selected {! $slider_selected}}
            {if_else $slider_selected
               {do
                  {set $slider_type audio}
                  {$this show_tooltip}
               }
               {$this hide_tooltip}
            }
         )
         ("Per-Controller Calibration"
            {$this show_state dxState_ControllerCalibration}
         )
      }
      {$this trigger_select_effects}
   )
   (LIST_FOCUS_MSG
      {local $ui_list {$this get_ui_list }}
      {local $list_data {$ui_list get_data_in_column token}}
      {if_else $slider_selected
         {if_else $setting_focus
            {set $setting_focus FALSE}
            {switch $slider_type
               (video
                  {if_else {== $list_data " "} ;up
                     {unless {< {- {get_video_calibration} 1} -300}
                        {set_video_calibration {- {get_video_calibration} 1}}
                     }
                     {unless {> {+ {get_video_calibration} 1} 300}
                        {set_video_calibration {+ {get_video_calibration} 1}}
                     }
                  }
                  CALIBRATION_DATA
                  {set $setting_focus TRUE}
                  {$ui_list set_focus_by_data dx_index 1}
               )
               (audio
                  {if_else {== $list_data {sprintf " - Video: %d ms + " {* {get_video_calibration} -1}}} ;up
                     {unless {< {- {get_audio_calibration} 1} -300}
                        {set_audio_calibration {- {get_audio_calibration} 1}}
                     }
                     {unless {> {+ {get_audio_calibration} 1} 300}
                        {set_audio_calibration {+ {get_audio_calibration} 1}}
                     }
                  }
                  CALIBRATION_DATA
                  {set $setting_focus TRUE}
                  {$ui_list set_focus_by_data dx_index 2}
               )
            }
         }
         {if {== $list_data " "}
            {$ui_list set_focus_by_data dx_index 1}
         }
      }
   )
   (UI_BUTTON_DOWN_MSG
      {local $list_data {{$this get_ui_list} get_data_in_column token}}
      {if_else {|| {== $action kAction_Right } {== $action kAction_Left }}
         {do
            {if_else {== $action kAction_Right } ;also up
               {switch $list_data
                  ({sprintf " - Video: %d ms + " {* {get_video_calibration} -1}}
                     {unless {< {- {get_video_calibration} 1} -300}
                        {set_video_calibration {- {get_video_calibration} 1}}
                     }
                  )
                  ({sprintf " - Audio: %d ms + " {* {get_audio_calibration} -1}}
                     {unless {< {- {get_audio_calibration} 1} -300}
                        {set_audio_calibration {- {get_audio_calibration} 1}}
                     }
                  )
               }
               {switch $list_data
                  ({sprintf " - Video: %d ms + " {* {get_video_calibration} -1}}
                     {unless {> {+ {get_video_calibration} 1} 300}
                        {set_video_calibration {+ {get_video_calibration} 1}}
                     }
                  )
                  ({sprintf " - Audio: %d ms + " {* {get_audio_calibration} -1}}
                     {unless {> {+ {get_audio_calibration} 1} 300}
                        {set_audio_calibration {+ {get_audio_calibration} 1}}
                     }
                  )
               }
            }
            CALIBRATION_DATA
         }
         {if_else {== $action kAction_Cancel}
            {if_else $slider_selected
               {do
                  {set $slider_selected FALSE}
                  {$this trigger_cancel_effects}
               }
               {do
                  {write_file "data:/GoldHEN/RB4DX/videocalib.ini" {array ({get_video_calibration})}}
                  {write_file "data:/GoldHEN/RB4DX/audiocalib.ini" {array ({get_audio_calibration})}}
                  {$this show_state dxState_GPSettings}
                  {$this trigger_cancel_effects}
               }
            }
            {if_else {== $action kAction_Option}
               {if $slider_selected
                  {switch $list_data
                     ({sprintf " - Video: %d ms + " {* {get_video_calibration} -1}}
                        {set_video_calibration 0}
                     )
                     ({sprintf " - Audio: %d ms + " {* {get_audio_calibration} -1}}
                        {set_audio_calibration 0}
                     )
                  }
                  CALIBRATION_DATA
               }
               kDataUnhandled
            }
         }
      }
   )
   (on_cancel)
)

#define PER_CONTROLLER_CALIBRATION_DATA
(
   {set $dxsettings {array ()}}
   {push_back $dxsettings " "}
   {push_back $dxsettings {sprintf " - Dualshock: %d ms + " {* {get_plugin_var pad_extra_lag} -1}}}
   {push_back $dxsettings {sprintf " - Rock Band 1 Guitar: %d ms + " {* {get_plugin_var rb1_guitar_extra_lag} -1}}}
   {push_back $dxsettings {sprintf " - Rock Band 2/3 Guitar: %d ms + " {* {get_plugin_var rb2_guitar_extra_lag} -1}}}
   {push_back $dxsettings {sprintf " - Rock Band 4 Stratocaster: %d ms + " {* {get_plugin_var rb4_strat_extra_lag} -1}}}
   {push_back $dxsettings {sprintf " - Rock Band 4 Jaguar/Riffmaster: %d ms + " {* {get_plugin_var rb4_jag_extra_lag} -1}}}
   {push_back $dxsettings {sprintf " - Guitar Hero Guitar: %d ms + " {* {get_plugin_var gh_guitar_extra_lag} -1}}}
   {push_back $dxsettings {sprintf " - Rock Band 1 Drums: %d ms + " {* {get_plugin_var rb1_drums_extra_lag} -1}}}
   {push_back $dxsettings {sprintf " - Rock Band 2/3 Drums: %d ms + " {* {get_plugin_var rb2_drums_extra_lag} -1}}}
   {push_back $dxsettings {sprintf " - Rock Band 4 Drums: %d ms + " {* {get_plugin_var rb4_drums_extra_lag} -1}}}
   {push_back $dxsettings {sprintf " - Guitar Hero Drums: %d ms + " {* {get_plugin_var gh_drums_extra_lag} -1}}}
   {push_back $dxsettings {sprintf " - Rock Revolution Drums: %d ms + " {* {get_plugin_var rr_drums_extra_lag} -1}}}
   {push_back $dxsettings {sprintf " - MIDI Pro Adapter Drums: %d ms + " {* {get_plugin_var mpa_drums_extra_lag} -1}}}
   {push_back $dxsettings "  "}
   {$this setup_confirm_actions a $dxsettings}
)
#define PER_CONTROLLER_CALIBRATION_RESET
(
   {switch $selected_pad_type
      ("Dualshock"
         {set_plugin_var pad_extra_lag 0}
      )
      ("Rock Band 1 Guitar"
         {set_plugin_var rb1_guitar_extra_lag -13}
      )
      ("Rock Band 2/3 Guitar"
         {set_plugin_var rb2_guitar_extra_lag -31}
      )
      ("Rock Band 4 Stratocaster"
         {set_plugin_var rb4_strat_extra_lag 1}
      )
      ("Rock Band 4 Jaguar/Riffmaster"
         {set_plugin_var rb4_jag_extra_lag 1}
      )
      ("Guitar Hero Guitar"
         {set_plugin_var gh_guitar_extra_lag -3}
      )
      ("Rock Band 1 Drums"
         {set_plugin_var rb1_drums_extra_lag 26}
      )
      ("Rock Band 2/3 Drums"
         {set_plugin_var rb2_drums_extra_lag 26}
      )
      ("Rock Band 4 Drums"
         {set_plugin_var rb4_drums_extra_lag 26}
      )
      ("Guitar Hero Drums"
         {set_plugin_var gh_drums_extra_lag 26}
      )
      ("Rock Revolution Drums"
         {set_plugin_var rr_drums_extra_lag 26}
      )
      ("MIDI Pro Adapter Drums"
         {set_plugin_var mpa_drums_extra_lag 26}
      )
   }
)
#define PER_CONTROLLER_CALIBRATION_SAVE
(
   {switch $selected_pad_type
      ("Dualshock"
         {write_file "data:/GoldHEN/RB4DX/settings/calibration/pad.dta" {array ({get_plugin_var pad_extra_lag})}}
      )
      ("Rock Band 1 Guitar"
         {write_file "data:/GoldHEN/RB4DX/settings/calibration/rb1_guitar.dta" {array ({get_plugin_var rb1_guitar_extra_lag})}}
      )
      ("Rock Band 2/3 Guitar"
         {write_file "data:/GoldHEN/RB4DX/settings/calibration/rb2_guitar.dta" {array ({get_plugin_var rb2_guitar_extra_lag})}}
      )
      ("Rock Band 4 Stratocaster"
         {write_file "data:/GoldHEN/RB4DX/settings/calibration/rb4_strat.dta" {array ({get_plugin_var rb4_strat_extra_lag})}}
      )
      ("Rock Band 4 Jaguar/Riffmaster"
         {write_file "data:/GoldHEN/RB4DX/settings/calibration/rb4_jag.dta" {array ({get_plugin_var rb4_jag_extra_lag})}}
      )
      ("Guitar Hero Guitar"
         {write_file "data:/GoldHEN/RB4DX/settings/calibration/gh_guitar.dta" {array ({get_plugin_var gh_guitar_extra_lag})}}
      )
      ("Rock Band 1 Drums"
         {write_file "data:/GoldHEN/RB4DX/settings/calibration/rb1_drums.dta" {array ({get_plugin_var rb1_drums_extra_lag})}}
      )
      ("Rock Band 2/3 Drums"
         {write_file "data:/GoldHEN/RB4DX/settings/calibration/rb2_drums.dta" {array ({get_plugin_var rb2_drums_extra_lag})}}
      )
      ("Rock Band 4 Drums"
         {write_file "data:/GoldHEN/RB4DX/settings/calibration/rb4_drums.dta" {array ({get_plugin_var rb4_drums_extra_lag})}}
      )
      ("Guitar Hero Drums"
         {write_file "data:/GoldHEN/RB4DX/settings/calibration/gh_drums.dta" {array ({get_plugin_var gh_drums_extra_lag})}}
      )
      ("Rock Revolution Drums"
         {write_file "data:/GoldHEN/RB4DX/settings/calibration/rr_drums.dta" {array ({get_plugin_var rr_drums_extra_lag})}}
      )
      ("MIDI Pro Adapter Drums"
         {write_file "data:/GoldHEN/RB4DX/settings/calibration/mpa_drums.dta" {array ({get_plugin_var mpa_drums_extra_lag})}}
      )
   }
)

(dxState_ControllerCalibration
   (view {$this get_auto_list_view}) 
   (enter 
      PER_CONTROLLER_CALIBRATION_DATA
      {set $slider_selected FALSE}
      {$this setup_tooltip kAction_Option os_reset} ;41 char limit
      {$this reset_list_focus }
   )
   (SELECT_MSG 
      {local $list_data {($objId UIListCom) get_data_in_column token}}  
      {set $slider_selected {! $slider_selected}}
      {switch $list_data 
         ({sprintf " - Dualshock: %d ms + " {* {get_plugin_var pad_extra_lag} -1}}
            {if_else $slider_selected
               {do
                  {set $selected_pad_type "Dualshock"}
                  {$this show_tooltip}
               }
               {$this hide_tooltip}
            }
         )
         ({sprintf " - Rock Band 1 Guitar: %d ms + " {* {get_plugin_var rb1_guitar_extra_lag} -1}}
            {if_else $slider_selected
               {do
                  {set $selected_pad_type "Rock Band 1 Guitar"}
                  {$this show_tooltip}
               }
               {$this hide_tooltip}
            }
         )
         ({sprintf " - Rock Band 2/3 Guitar: %d ms + " {* {get_plugin_var rb2_guitar_extra_lag} -1}}
            {if_else $slider_selected
               {do
                  {set $selected_pad_type "Rock Band 2/3 Guitar"}
                  {$this show_tooltip}
               }
               {$this hide_tooltip}
            }
         )
         ({sprintf " - Rock Band 4 Stratocaster: %d ms + " {* {get_plugin_var rb4_strat_extra_lag} -1}}
            {if_else $slider_selected
               {do
                  {set $selected_pad_type "Rock Band 4 Stratocaster"}
                  {$this show_tooltip}
               }
               {$this hide_tooltip}
            }
         )
         ({sprintf " - Rock Band 4 Jaguar/Riffmaster: %d ms + " {* {get_plugin_var rb4_jag_extra_lag} -1}}
            {if_else $slider_selected
               {do
                  {set $selected_pad_type "Rock Band 4 Jaguar/Riffmaster"}
                  {$this show_tooltip}
               }
               {$this hide_tooltip}
            }
         )
         ({sprintf " - Guitar Hero Guitar: %d ms + " {* {get_plugin_var gh_guitar_extra_lag} -1}}
            {if_else $slider_selected
               {do
                  {set $selected_pad_type "Guitar Hero Guitar"}
                  {$this show_tooltip}
               }
               {$this hide_tooltip}
            }
         )
         ({sprintf " - Rock Band 1 Drums: %d ms + " {* {get_plugin_var rb1_drums_extra_lag} -1}}
            {if_else $slider_selected
               {do
                  {set $selected_pad_type "Rock Band 1 Drums"}
                  {$this show_tooltip}
               }
               {$this hide_tooltip}
            }
         )
         ({sprintf " - Rock Band 2/3 Drums: %d ms + " {* {get_plugin_var rb2_drums_extra_lag} -1}}
            {if_else $slider_selected
               {do
                  {set $selected_pad_type "Rock Band 2/3 Drums"}
                  {$this show_tooltip}
               }
               {$this hide_tooltip}
            }
         )
         ({sprintf " - Rock Band 4 Drums: %d ms + " {* {get_plugin_var rb4_drums_extra_lag} -1}}
            {if_else $slider_selected
               {do
                  {set $selected_pad_type "Rock Band 4 Drums"}
                  {$this show_tooltip}
               }
               {$this hide_tooltip}
            }
         )
         ({sprintf " - Guitar Hero Drums: %d ms + " {* {get_plugin_var gh_drums_extra_lag} -1}}
            {if_else $slider_selected
               {do
                  {set $selected_pad_type "Guitar Hero Drums"}
                  {$this show_tooltip}
               }
               {$this hide_tooltip}
            }
         )
         ({sprintf " - Rock Revolution Drums: %d ms + " {* {get_plugin_var rr_drums_extra_lag} -1}}
            {if_else $slider_selected
