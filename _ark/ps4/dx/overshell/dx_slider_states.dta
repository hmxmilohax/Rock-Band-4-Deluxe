                  {if_else {== $list_data {sprintf " - Dualshock: %d ms + " {* {get_plugin_var pad_extra_lag} -1}}} ;up
                     {unless {< {- {get_plugin_var rb1_guitar_extra_lag} 1} -1000}
                        {set_plugin_var rb1_guitar_extra_lag {- {get_plugin_var rb1_guitar_extra_lag} 1}}
