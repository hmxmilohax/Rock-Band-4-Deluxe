(dxState_RGBSlider
   (view confirm_action) 
   (enter 
      RGB_DATA
   )
   (SELECT_MSG 
      {local $list_data {($objId UIListCom) get_data_in_column token}}  
      {switch $list_data 
         ("+"
            RGB_ADD
            RGB_DATA
         )
         (os_reset
            RGB_RESET
            RGB_DATA
         )
         ("-"
            RGB_SUB
            RGB_DATA
         )
      }
   )
   (on_cancel 
      {$this show_state dxState_RGBSelect}
      {$this trigger_cancel_effects}
   )
)

(dxState_RGBIntervalSlider
   (view confirm_action) 
   (enter 
      {$this setup_confirm_actions {sprintf "RGB Adjustment Interval: %dX" $rgbint} ("+" os_reset "-")}
   )
   (SELECT_MSG 
      {local $list_data {($objId UIListCom) get_data_in_column token}}  
      {switch $list_data 
         ("+"
            {switch $rgbint
               (50
                  {set $rgbint 100}
               )
               (25
                  {set $rgbint 50}
               )
               (10
                  {set $rgbint 25}
               )
               (5
                  {set $rgbint 10}
               )
               (1
                  {set $rgbint 5}
               )
            }
            {$this setup_confirm_actions {sprintf "RGB Adjustment Interval: %dX" $rgbint} ("+" os_reset "-")}
         )
         (os_reset
            {set $rgbint 1}
            {$this setup_confirm_actions {sprintf "RGB Adjustment Interval: %dX" $rgbint} ("+" os_reset "-")}
         )
         ("-"
            {switch $rgbint
               (100
                  {set $rgbint 50}
               )
               (50
                  {set $rgbint 25}
               )
               (25
                  {set $rgbint 10}
               )
               (10
                  {set $rgbint 5}
               )
               (5
                  {set $rgbint 1}
               )
            }
            {$this setup_confirm_actions {sprintf "RGB Adjustment Interval: %dX" $rgbint} ("+" os_reset "-")}
         )
      }
   )
   (on_cancel
      {$this show_state dxState_RGBSelect}
      {$this trigger_cancel_effects}
   )
)

#define POSITION_DATA
