               {set $voxcountdownposx 0.0}
            )
            (Y
               {set $voxcountdownposy 250.0}
            )
            (Z
               {set $voxcountdownposz 50.0}
            )
         }
      )
   }
)
(dxState_PositionSlider
   (view confirm_action) 
   (enter 
      POSITION_DATA
   )
   (SELECT_MSG 
      {local $list_data {($objId UIListCom) get_data_in_column token}}  
      {switch $list_data 
         ("+"
            POSITION_ADD
            POSITION_DATA
         )
         (os_reset
            POSITION_RESET
            POSITION_DATA
         )
         ("-"
            POSITION_SUB
            POSITION_DATA
         )
      }
   )
   (on_cancel
      {if_else {== $positiontype "mtv"}
         {$this show_state dxState_SongTitlePosition}
         {$this show_state dxState_HUDPosition}
      }
      {$this trigger_cancel_effects}
   )
)

(dxState_PositionIntervalSlider
   (view confirm_action) 
   (enter 
      {$this setup_confirm_actions {sprintf "Position Adjustment Interval: %.2fX" $posint} ("+" os_reset "-")}
   )
   (SELECT_MSG 
      {local $list_data {($objId UIListCom) get_data_in_column token}}  
      {switch $list_data 
         ("+"
            {switch $posint
               (50
                  {set $posint 100}
               )
               (25
                  {set $posint 50}
               )
               (10
                  {set $posint 25}
               )
               (5
                  {set $posint 10}
               )
               (1
                  {set $posint 5}
               )
               (0.5
                  {set $posint 1}
               )
               (0.25
                  {set $posint 0.5}
               )
            }
            {$this setup_confirm_actions {sprintf "Position Adjustment Interval: %.2fX" $posint} ("+" os_reset "-")}
         )
         (os_reset
            {set $posint 0.5}
            {$this setup_confirm_actions {sprintf "Position Adjustment Interval: %.2fX" $posint} ("+" os_reset "-")}
         )
         ("-"
            {switch $posint
               (100
                  {set $posint 50}
               )
               (50
                  {set $posint 25}
               )
               (25
                  {set $posint 10}
               )
               (10
                  {set $posint 5}
               )
               (5
                  {set $posint 1}
               )
               (1
                  {set $posint 0.5}
               )
               (0.5
                  {set $posint 0.25}
               )
            }
            {$this setup_confirm_actions {sprintf "Position Adjustment Interval: %.2fX" $posint} ("+" os_reset "-")}
         )
      }
   )
   (on_cancel
      {if_else {== $positiontype "mtv"}
         {$this show_state dxState_SongTitlePosition}
         {$this show_state dxState_HUDPosition}
      }
      {$this trigger_cancel_effects}
   )
)