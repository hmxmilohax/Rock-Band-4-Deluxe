                        {set_plugin_var rr_drums_extra_lag {- {get_plugin_var rr_drums_extra_lag} 1}}
                     }
                     {unless {> {+ {get_plugin_var rr_drums_extra_lag} 1} 1000}
                        {set_plugin_var rr_drums_extra_lag {+ {get_plugin_var rr_drums_extra_lag} 1}}
                     }
                  }
                  PER_CONTROLLER_CALIBRATION_DATA
                  {set $setting_focus TRUE}
                  {$ui_list set_focus_by_data dx_index 11}
               )
               ("MIDI Pro Adapter Drums"
                  {if_else {== $list_data {sprintf " - Rock Revolution Drums: %d ms + " {* {get_plugin_var rr_drums_extra_lag} -1}}} ;up
                     {unless {< {- {get_plugin_var mpa_drums_extra_lag} 1} -1000}
                        {set_plugin_var mpa_drums_extra_lag {- {get_plugin_var mpa_drums_extra_lag} 1}}
                     }
                     {unless {> {+ {get_plugin_var mpa_drums_extra_lag} 1} 1000}
                        {set_plugin_var mpa_drums_extra_lag {+ {get_plugin_var mpa_drums_extra_lag} 1}}
                     }
                  }
                  PER_CONTROLLER_CALIBRATION_DATA
                  {set $setting_focus TRUE}
                  {$ui_list set_focus_by_data dx_index 12}
               )
            }
         }
         {if_else {== $list_data " "}
            {$ui_list set_focus_by_data dx_index 1}
            {if {== $list_data "  "}
               {$ui_list set_focus_by_data dx_index 12}
            }
         }
      }
   )
   (UI_BUTTON_DOWN_MSG
      {local $list_data {{$this get_ui_list} get_data_in_column token}}
      {if_else {|| {== $action kAction_Right } {== $action kAction_Left }}
         {do
            {if_else {== $action kAction_Right } ;also up
               {switch $list_data
                  ({sprintf " - Dualshock: %d ms + " {* {get_plugin_var pad_extra_lag} -1}}
                     {unless {< {- {get_plugin_var pad_extra_lag} 1} -1000}
                        {set_plugin_var pad_extra_lag {- {get_plugin_var pad_extra_lag} 1}}
                     }
                  )
                  ({sprintf " - Rock Band 1 Guitar: %d ms + " {* {get_plugin_var rb1_guitar_extra_lag} -1}}
