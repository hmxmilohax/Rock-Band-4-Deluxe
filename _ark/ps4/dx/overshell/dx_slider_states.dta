#define POSITION_ADD
(
   {switch $positiontype
      ("mtv"
         {switch $positionchanged
            (X
               {set $mtvposx {+ $mtvposx $posint}}
            )
            (Y
               {set $mtvposy {+ $mtvposy $posint}}
            )
            (Z
               {set $mtvposz {+ $mtvposz $posint}}
            )
         }
      )
      ("solo"
         {switch $positionchanged
            (X
               {set $soloposx {+ $soloposx $posint}}
            )
            (Y
